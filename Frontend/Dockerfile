# ============================================================
# Dockerfile del FRONTEND (Angular) - build multi-etapa
# Etapa 1: compilar la aplicación
# Etapa 2: servirla con nginx
# ============================================================

# ---------- Etapa 1: build ----------
FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# ---------- Etapa 2: nginx ----------
FROM nginx:alpine
# La salida de Angular moderno queda en dist/frontend/browser
COPY --from=build /app/dist/frontend/browser /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
